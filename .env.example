# Configuración de Entorno para Cyber-Inventory
# Copia este archivo a .env y ajusta según necesario

# ==================== SERVIDOR ====================
# Host para el servidor
SERVER_HOST=0.0.0.0

# Puerto para el servidor
SERVER_PORT=8000

# Modo debug (True para desarrollo, False para producción)
DEBUG=True

# ==================== BASE DE DATOS ====================
# URL de conexión a la base de datos
# Formato: sqlite:///./nombre_archivo.db (SQLite)
DATABASE_URL=sqlite:///./warehouse.db

# Echo de queries SQL (para debugging)
SQL_ECHO=False

# ==================== CORS ====================
# Orígenes permitidos (separados por comas)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ==================== SEGURIDAD ====================
# Clave secreta para JWT (generar con: python -c "import secrets; print(secrets.token_urlsafe(32))")
# SECRET_KEY=your-secret-key-here

# Algoritmo JWT
# JWT_ALGORITHM=HS256

# Tiempo de expiración del token (minutos)
# JWT_EXPIRATION_MINUTES=30

# ==================== LOGGING ====================
# Nivel de log
LOG_LEVEL=INFO

# Archivo de log
# LOG_FILE=logs/app.log

# ==================== CARACTERÍSTICAS ====================
# Habilitar documentación Swagger
ENABLE_SWAGGER=True

# Habilitar ReDoc
ENABLE_REDOC=True

# ==================== TESTING ====================
# Base de datos para testing (en memoria)
TEST_DATABASE_URL=sqlite:///:memory:

# ==================== NOTAS ====================
# Este archivo es un ejemplo. Para usarlo:
# 1. Copia este archivo a un nuevo archivo llamado .env
# 2. Ajusta los valores según tu configuración
# 3. Las variables se cargarán automáticamente en app/config.py
